{
  "manifest_version": 3,
  "name": "Digital Leap HRMS",
  "version": "1.1.0",
  "description": "Clock in & out for Digital Leap employees — attendance tracked directly to HRMS.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://hr.digitalleapmarketing.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Digital Leap HRMS",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
