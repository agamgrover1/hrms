{
  "manifest_version": 3,
  "name": "Digital Leap HRMS",
  "version": "1.2.0",
  "description": "Clock in/out and activity tracking for Digital Leap employees.",
  "permissions": ["storage", "alarms", "notifications", "idle"],
  "host_permissions": ["https://hr.digitalleapmarketing.com/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Digital Leap HRMS",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
